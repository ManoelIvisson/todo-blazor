@page "/"
@using System.Threading.Tasks
@inject IJSRuntime JS
@inject HttpClient Http;

<PageTitle>Início</PageTitle>

<h1>Bem-vindo ao TodoBlaze!</h1>

<p>Organize suas tarefas rapidamente.</p>

<button @onclick="ToggleForm" class="btn btn-primary">
    <span> <i class="bi bi-plus"></i> Nova tarefa</span>
</button>

@if (showForm)
{
    <div class="mt-3">
        <EditForm Model="newTodo" OnValidSubmit="AddTodo">
    
            <InputText Placeholder="Título da tarefa" class="form-control" @bind-Value="newTodo.Title" aria-placeholder="Titulo da tarefa"/>
            <InputText Placeholder="Descrição" class="form-control mt-2" @bind-Value="newTodo.Description"/>
            <button class="btn btn-primary mt-2">
                Adicionar
            </button>
            <button class="btn btn-danger mt-2" @onclick="ToggleForm">Cancelar</button>
        </EditForm>
    </div>
}

<div class="todo-grid" @ref="listElement">
    @foreach (var todo in todos)
    {
        <div class="card">
            <div class="d-flex flex-row justify-content-between">
                <div class="col-10">
                    @todo.Title
                </div>
                <button class="col-auto btn p-0 align-self-start" data-bs-toggle="collapse" data-bs-target="#todo-@todo.Id" >
                    <i class="bi bi-plus fs-4"></i>
                </button>
            </div>
            <div id="todo-@todo.Id" class="mt-2 collapse">@todo.Description</div>
        </div>
    }
</div>

@code
{
    private bool showForm = false;
    private List<TodoItem>? todos = new();
    private TodoItem newTodo = new();
    private ElementReference listElement;

    protected override async Task OnInitializedAsync()
    {
        TodoItem todoToday = new TodoItem() { Title = "Estudar" };
        TodoItem todoYesterday = new TodoItem() { Title = "Treinar" };
        TodoItem todoTomorrow = new TodoItem() { Title = "Jogar Monster Hunter Rise" };
        await LoadTodos();
        todos.Add(todoToday);
        todos.Add(todoYesterday);
        todos.Add(todoTomorrow);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initSortable", listElement);
        }
    }

    void ToggleForm()
    {
        showForm = !showForm;
    } 

    async Task AddTodo()
    {
        await Http.PostAsJsonAsync("/todos", newTodo);

        todos.Add(newTodo);

        newTodo = new();
        showForm = false;
        await LoadTodos();
    }

    async Task LoadTodos()
    {
        todos = await Http.GetFromJsonAsync<List<TodoItem>>("/todos");
        Console.WriteLine(todos);
    }
}